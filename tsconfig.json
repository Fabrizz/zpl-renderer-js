{
  "compilerOptions": {
    "lib": ["ES2020", "DOM"],
    "target": "ES2018",
    "module": "ESNext",
    "declaration": true,
    "emitDeclarationOnly": true,
    "rootDir": "./src",
    "outDir": "dist",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": true
  },
  "include": ["src", "types"],
  "exclude": ["node_modules", "dist", "web"]
}